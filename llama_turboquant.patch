+    // Apply signs + 512-point WHT
+    for (int j = 0; j < 512; j++) { int sign = ((tbq_signs_512[j>>3]>>(j&7))&1)?-1:1; tmp[j] *= sign; }
+    for (int len = 1; len < 512; len *= 2)
