+    for (int j = 0; j < TBQ_K128/8; j++) y->qjl[j] = 0;
+    for (int j = 0; j < TBQ_K128; j++) {
+        if (res[j] >= 0.0f) y->qjl[j/8] |= (1 << (j%8));
+    }
+}
