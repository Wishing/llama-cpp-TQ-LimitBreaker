+static __device__ __forceinline__ float vec_dot_fattn_vec_KQ_tbqp3_1(
+    const char * __restrict__ K_c, const void * __restrict__ Q_v, const int * __restrict__ Q_q8, const void * __restrict__ Q_ds_v) {
