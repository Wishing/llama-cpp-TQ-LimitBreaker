+    // Global norm for TBQP4: QJL residual uses cross-block 512-WHT
+    float global_sq = 0.0f;
+    for (int j = 0; j < 512; j++) global_sq += tmp[j] * tmp[j];
+    float global_norm = sqrtf(global_sq / 512.0f);
