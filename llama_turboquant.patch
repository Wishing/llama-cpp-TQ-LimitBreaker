+        for (int j = 0; j < TBQ_K64/8; j++) outs[h]->qjl[j] = 0;
+        for (int j = 0; j < TBQ_K64; j++) { if (seg[j] * inv_norm - recon[j] >= 0.0f) outs[h]->qjl[j/8] |= (1<<(j%8)); }
+    }
+}
