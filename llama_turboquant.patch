+            uint8_t idx0 = 15, idx1 = 15;
+            float val0 = blk[2*j]   * inv_norm;
+            float val1 = blk[2*j+1] * inv_norm;
+            for (int b = 0; b < 15; b++) { if (val0 < b4[b]) { idx0 = b; break; } }
+            for (int b = 0; b < 15; b++) { if (val1 < b4[b]) { idx1 = b; break; } }
