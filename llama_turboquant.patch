+    block_tbq4_3 * outs[8] = { y0,y1,y2,y3,y4,y5,y6,y7 };
+
+    float tmp[512];
+    for (int h = 0; h < 8; h++)
+        for (int j = 0; j < TBQ_K64; j++)
+            tmp[h*TBQ_K64+j] = heads[h][j];
+
+    // Apply signs + 512-point WHT
+    for (int j = 0; j < 512; j++) { int sign = ((tbq_signs_512[j>>3]>>(j&7))&1)?-1:1; tmp[j] *= sign; }
