+    float inv_norm = 1.0f / norm;
+    for (int j = 0; j < QK_K; j++) {
+        int sign = ((tbq_signs[j >> 3] >> (j & 7)) & 1) ? -1 : 1;
+        tmp[j] = x[j] * inv_norm * sign;
+    }
+
+    // Step 3: Serial WHT (single thread, QK_K=256)
+    for (int len = 1; len < QK_K; len *= 2) {
+        for (int i = 0; i < QK_K; i += 2 * len) {
+            for (int j = 0; j < len; j++) {
