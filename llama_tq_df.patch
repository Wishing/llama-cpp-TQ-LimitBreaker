--- /dev/null
+++ b/src/models/dflash_draft.cpp
@@ -0,0 +1,335 @@
+#include "models.h"
+#include "../llama-impl.h"
+
+#include <algorithm>
+#include <atomic>
+#include <vector>
+#include <cstdio>
+
+// Max cross-attention context for DFlash drafter (caps VRAM growth).
+// Override with GGML_DFLASH_MAX_CTX env var. 0 = unlimited.
+static int64_t dflash_max_cross_ctx() {
+    static const int64_t val = [] {
+        const char * e = getenv("GGML_DFLASH_MAX_CTX");
+        return e ? (int64_t) atoi(e) : (int64_t) 4096;
+    }();
+    return val;
+}
+
+// DFlash drafter custom graph input
+// Holds the target hidden states, context positions, and asymmetric non-causal attention mask
+class llm_graph_input_dflash_draft : public llm_graph_input_i {
+public:
+    llm_graph_input_dflash_draft(const llama_cross * cross, int64_t ctx_len, int64_t n_block, uint32_t n_swa, int32_t n_slots)
+        : cross(cross), ctx_len(ctx_len), n_block(n_block), n_swa(n_swa), n_slots(n_slots) {}
+
+    void set_input(const llama_ubatch * ubatch) override;
+
+    ggml_tensor * target_hidden     = nullptr; // [n_target_features, ctx_len]
+    ggml_tensor * pos_ctx           = nullptr; // [ctx_len]
+    ggml_tensor * kq_mask           = nullptr; // [ctx_len + n_block, n_block, 1, 1]
+    ggml_tensor * kq_mask_cnv       = nullptr;
+    // Only allocated when hparams.is_swa_any(); same shape as kq_mask
+    ggml_tensor * kq_mask_swa       = nullptr;
+    ggml_tensor * kq_mask_swa_cnv   = nullptr;
+
+    const llama_cross * cross;
+    int64_t ctx_len;
+    int64_t n_block;
+    uint32_t n_swa;
+    int32_t n_slots;
+};
+
+void llm_graph_input_dflash_draft::set_input(const llama_ubatch * ubatch) {
+    const int n_seqs_batch = (ubatch && ubatch->n_seqs_unq > 0) ? (int) ubatch->n_seqs_unq : 1;
+    const int n_slots_to_fill = std::min(n_seqs_batch, (int)n_slots);
+
+    // Default: clear everything if no slots to fill
+    if (n_slots_to_fill <= 0) {
+        if (target_hidden) ggml_backend_tensor_memset(target_hidden, 0, 0, ggml_nbytes(target_hidden));
+        return;
+    }
+
+    for (int s = 0; s < n_slots_to_fill; ++s) {
+        const llama_seq_id active_seq = (ubatch && ubatch->seq_id_unq) ? ubatch->seq_id_unq[s] : (llama_seq_id)0;
+        
+        // resolve cross data for the active seq (GPU path preferred, CPU fallback)
+        const float * src_data  = nullptr;
+        const void *  src_gpu   = nullptr;
+        int64_t       src_n_real = 0;
+        
+        if (cross) {
+            auto it = cross->v_embd_per_seq.find(active_seq);
+            if (it != cross->v_embd_per_seq.end()) {
+                if (it->second.v_embd_gpu) {
+                    src_gpu    = it->second.v_embd_gpu;
+                    src_n_real = it->second.v_embd_gpu_n_enc_real;
+                } else if (!it->second.v_embd.empty()) {
+                    src_data   = it->second.v_embd.data();
+                    src_n_real = it->second.n_enc_real;
+                }
+            }
+            if (!src_data && !src_gpu) {
+                // Fallback to global cross data if per-seq not found
+                if (cross->v_embd_gpu) {
+                    src_gpu    = cross->v_embd_gpu;
+                    src_n_real = cross->v_embd_gpu_n_enc_real;
+                } else if (!cross->v_embd.empty()) {
+                    src_data   = cross->v_embd.data();
+                    src_n_real = cross->n_enc_real;
+                }
+            }
+        }
+
+        const int64_t src_real = src_n_real > 0 ? src_n_real : 0;
+        const int64_t n_copy   = std::min(src_real, ctx_len);
+        const int64_t win_off  = (src_real > ctx_len) ? (src_real - ctx_len) : 0;
+
+        if (target_hidden && (src_data || src_gpu) && n_copy > 0) {
+            const int64_t n_feat = cross->n_embd;
+            const size_t copy_bytes   = (size_t) n_feat * (size_t) n_copy * sizeof(float);
+            const size_t slot_bytes   = (size_t) n_feat * (size_t) ctx_len * sizeof(float);
+            const size_t actual_bytes = std::min(copy_bytes, slot_bytes);
+            const size_t dst_off      = (size_t) s * slot_bytes;
+
+            if (src_gpu && cross->fn_set_tensor_d2d) {
+                const void * gpu_src = (const char *)src_gpu + (size_t)win_off * n_feat * sizeof(float);
+                cross->fn_set_tensor_d2d(target_hidden->data, gpu_src, dst_off, actual_bytes);
+            } else if (src_data) {
+                const float * src = src_data + win_off * n_feat;
+                ggml_backend_tensor_set(target_hidden, src, dst_off, actual_bytes);
+            }
+            // Clear rest of the slot if n_copy < ctx_len
+            if (actual_bytes < slot_bytes) {
+                ggml_backend_tensor_memset(target_hidden, 0, dst_off + actual_bytes, slot_bytes - actual_bytes);
+            }
+        } else if (target_hidden) {
+            const size_t slot_bytes = (size_t) cross->n_embd * (size_t) ctx_len * sizeof(float);
+            ggml_backend_tensor_memset(target_hidden, 0, (size_t) s * slot_bytes, slot_bytes);
+        }
+
+        const int64_t n_real = n_copy;
+
+        if (pos_ctx && pos_ctx->buffer) {
+            GGML_ASSERT(ggml_backend_buffer_is_host(pos_ctx->buffer));
+            int32_t * data = (int32_t *) pos_ctx->data + s * ctx_len;
+            for (int64_t i = 0; i < ctx_len; ++i) {
+                data[i] = (i < n_real) ? (int32_t) (win_off + i) : 0;
+            }
+        }
+
+        if (kq_mask && kq_mask->buffer) {
+            GGML_ASSERT(ggml_backend_buffer_is_host(kq_mask->buffer));
+            const int64_t n_kv = ctx_len + n_block;
+            float * data = (float *) kq_mask->data + s * n_block * n_kv;
+            for (int64_t q = 0; q < n_block; ++q) {
+                for (int64_t k = 0; k < n_kv; ++k) {
+                    if (k >= n_real && k < ctx_len) {
+                        data[q * n_kv + k] = -INFINITY;
+                    } else {
+                        data[q * n_kv + k] = 0.0f;
+                    }
+                }
+            }
+        }
+
+        if (kq_mask_swa && kq_mask_swa->buffer && n_swa > 0) {
+            GGML_ASSERT(ggml_backend_buffer_is_host(kq_mask_swa->buffer));
+            const int64_t n_kv   = ctx_len + n_block;
+            float * data = (float *) kq_mask_swa->data + s * n_block * n_kv;
+            const int32_t window = (int32_t) n_swa;
+            const bool    have_pos = (ubatch != nullptr) && (ubatch->pos != nullptr)
+                                   && ((int64_t) ubatch->n_tokens >= n_block);
+            for (int64_t q = 0; q < n_block; ++q) {
+                const int32_t q_pos = have_pos ? ubatch->pos[q] : (int32_t) (src_real + q);
+                for (int64_t k = 0; k < n_kv; ++k) {
+                    float v = 0.0f;
+                    if (k < n_real) {
+                        if (q_pos - (int32_t) (win_off + k) > window) v = -INFINITY;
+                    } else if (k < ctx_len) {
+                        v = -INFINITY;
+                    } else {
+                        const int64_t b_k = k - ctx_len;
+                        const int32_t k_pos = have_pos ? ubatch->pos[b_k] : (int32_t) (src_real + b_k);
+                        if (q_pos - k_pos > window || q_pos < k_pos) v = -INFINITY;
+                    }
+                    data[q * n_kv + k] = v;
+                }
+            }
+        }
+    }
+}
+
+llm_build_dflash_draft::llm_build_dflash_draft(const llama_model & model, const llm_graph_params & params)
+    : llm_graph_context(params) {
+
+    if (model.arch != LLM_ARCH_DFLASH_DRAFT) {
+        GGML_ABORT("llm_build_dflash_draft: fatal error, architecture mismatch!\n");
+    }
+
+    fprintf(stderr, "%s: dflash builder start\n", __func__); fflush(stderr);
+    const auto & hparams = model.hparams;
+    const auto & cparams = params.cparams;
+
+    const int64_t n_embd      = hparams.n_embd;
+    const int64_t n_embd_head = hparams.n_embd_head_v(0);
+    const int64_t n_head      = hparams.n_head(0);
+    const int64_t n_head_kv   = hparams.n_head_kv(0);
+    const int64_t n_layer     = hparams.n_layer;
+    const int64_t n_rot       = hparams.n_rot(0);
+
+    const auto & ubatch = params.ubatch;
+    const int64_t n_tokens = ubatch.n_tokens;
+
+    fprintf(stderr, "%s: resolving cross attention len, params.cross = %p\n", __func__, (const void*)params.cross); fflush(stderr);
+    int64_t ctx_len = 0;
+    if (params.cross) {
+        ctx_len = params.cross->n_enc;
+    }
+    int64_t max_cross_ctx = dflash_max_cross_ctx();
+    if (max_cross_ctx > 0 && ctx_len > max_cross_ctx) {
+        ctx_len = max_cross_ctx;
+    }
+
+    // 1. DFlash custom inputs
+    const int n_slots = cparams.dflash_n_slots;
+    auto inp_dflash = std::make_unique<llm_graph_input_dflash_draft>(params.cross, ctx_len, n_tokens, hparams.n_swa, n_slots);
+    auto inp_dflash_ptr = inp_dflash.get();
+    res->add_input(std::move(inp_dflash));
+
+    // 2. Token embedding
+    ggml_tensor * tok_embd_use = model.tok_embd;
+    if (!tok_embd_use) {
+        // Create a dummy token embedding tensor for the graph builder if the model doesn't have one
+        // (DFlash draft models don't embed tokens, they use target hidden states)
+        tok_embd_use = ggml_new_tensor_2d(ctx0, GGML_TYPE_Q4_0, n_embd, model.vocab.n_tokens());
+    }
+    ggml_tensor * cur = build_inp_embd(tok_embd_use);
+
+    // 3. Position embedding
+
+    ggml_tensor * t_pos = build_inp_pos();
+
+    // 4. Injection tensors
+    const int64_t n_target_features = hparams.dflash_n_target_features;
+    inp_dflash_ptr->target_hidden = ggml_new_tensor_2d(ctx0, GGML_TYPE_F32, n_target_features, ctx_len);
+    inp_dflash_ptr->pos_ctx       = ggml_new_tensor_1d(ctx0, GGML_TYPE_I32, ctx_len);
+    
+    ggml_set_name(inp_dflash_ptr->target_hidden, "target_hidden");
+    ggml_set_name(inp_dflash_ptr->pos_ctx,       "pos_ctx");
+    ggml_set_input(inp_dflash_ptr->target_hidden);
+    ggml_set_input(inp_dflash_ptr->pos_ctx);
+
+    const int64_t n_kv_total = ctx_len + n_tokens;
+    inp_dflash_ptr->kq_mask = ggml_new_tensor_4d(ctx0, GGML_TYPE_F32, n_kv_total, n_tokens, 1, 1);
+    ggml_set_name(inp_dflash_ptr->kq_mask, "kq_mask");
+    ggml_set_input(inp_dflash_ptr->kq_mask);
+    inp_dflash_ptr->kq_mask_cnv = cparams.flash_attn ? ggml_cast(ctx0, inp_dflash_ptr->kq_mask, GGML_TYPE_F16) : inp_dflash_ptr->kq_mask;
+
+    if (hparams.is_swa_any()) {
+        inp_dflash_ptr->kq_mask_swa = ggml_new_tensor_4d(ctx0, GGML_TYPE_F32, n_kv_total, n_tokens, 1, 1);
+        ggml_set_name(inp_dflash_ptr->kq_mask_swa, "kq_mask_swa");
+        ggml_set_input(inp_dflash_ptr->kq_mask_swa);
+        inp_dflash_ptr->kq_mask_swa_cnv = cparams.flash_attn ? ggml_cast(ctx0, inp_dflash_ptr->kq_mask_swa, GGML_TYPE_F16) : inp_dflash_ptr->kq_mask_swa;
+    }
+
+    // --- Fusion layer: project concatenated target hidden states ---
+    fprintf(stderr, "%s: before dflash_fc mul_mat, dflash_fc: [%ld, %ld], target_hidden: [%ld, %ld]\n", __func__, model.dflash_fc->ne[0], model.dflash_fc->ne[1], inp_dflash_ptr->target_hidden->ne[0], inp_dflash_ptr->target_hidden->ne[1]); fflush(stderr);
+    ggml_tensor * fused_target = ggml_mul_mat(ctx0, model.dflash_fc, inp_dflash_ptr->target_hidden);
+    fused_target = ggml_rms_norm(ctx0, fused_target, hparams.f_norm_rms_eps);
+    fused_target = ggml_mul(ctx0, fused_target, model.dflash_hidden_norm);
+
+    // 5. Transformer
+    for (int il = 0; il < n_layer; ++il) {
+        ggml_tensor * residual = cur;
+
+        // Norm
+        ggml_tensor * inpL = ggml_rms_norm(ctx0, cur, hparams.f_norm_rms_eps);
+        inpL = ggml_mul(ctx0, inpL, model.layers[il].attn_norm);
+
+        // Self-attention with injection
+        fprintf(stderr, "%s: before wq mul_mat il=%d\n", __func__, il); fflush(stderr);
+        ggml_tensor * Q = ggml_mul_mat(ctx0, model.layers[il].wq, inpL);
+        fprintf(stderr, "%s: before wk mul_mat il=%d\n", __func__, il); fflush(stderr);
+        ggml_tensor * K = ggml_mul_mat(ctx0, model.layers[il].wk, inpL);
+        fprintf(stderr, "%s: before wv mul_mat il=%d\n", __func__, il); fflush(stderr);
+        ggml_tensor * V = ggml_mul_mat(ctx0, model.layers[il].wv, inpL);
+
+        Q = ggml_rope_ext(ctx0, ggml_reshape_3d(ctx0, Q, n_embd_head, n_head, n_tokens),
+                          t_pos, nullptr, n_rot, hparams.rope_type, n_ctx_orig,
+                          freq_base, freq_scale, ext_factor,
+                          attn_factor, beta_fast, beta_slow);
+
+        K = ggml_rope_ext(ctx0, ggml_reshape_3d(ctx0, K, n_embd_head, n_head_kv, n_tokens),
+                          t_pos, nullptr, n_rot, hparams.rope_type, n_ctx_orig,
+                          freq_base, freq_scale, ext_factor,
+                          attn_factor, beta_fast, beta_slow);
+
+        fprintf(stderr, "%s: before target_K mul_mat il=%d\n", __func__, il); fflush(stderr);
+        ggml_tensor * target_K = ggml_mul_mat(ctx0, model.layers[il].wk, fused_target);
+        fprintf(stderr, "%s: before target_V mul_mat il=%d\n", __func__, il); fflush(stderr);
+        ggml_tensor * target_V = ggml_mul_mat(ctx0, model.layers[il].wv, fused_target);
+
+        target_K = ggml_reshape_3d(ctx0, target_K, n_embd_head, n_head_kv, ctx_len);
+        if (ctx_len > 0) {
+            target_K = ggml_rope_ext(ctx0, target_K,
+                                     inp_dflash_ptr->pos_ctx, nullptr, n_rot, hparams.rope_type, n_ctx_orig,
+                                     freq_base, freq_scale, ext_factor,
+                                     attn_factor, beta_fast, beta_slow);
+        }
+
+        V = ggml_reshape_3d(ctx0, V, n_embd_head, n_head_kv, n_tokens);
+        target_V = ggml_reshape_3d(ctx0, target_V, n_embd_head, n_head_kv, ctx_len);
+
+        K = ggml_concat(ctx0, target_K, K, 2);
+        V = ggml_concat(ctx0, target_V, V, 2);
+
+        ggml_tensor * mask = (hparams.n_swa > 0 && hparams.is_swa(il)) ? inp_dflash_ptr->kq_mask_swa_cnv : inp_dflash_ptr->kq_mask_cnv;
+        
+        cur = build_attn_mha(Q, K, V, nullptr, mask, nullptr, nullptr, 1.0f / sqrtf((float)n_embd_head), il);
+        
+        cur = ggml_mul_mat(ctx0, model.layers[il].wo, cur);
+
+        cur = ggml_add(ctx0, cur, residual);
+
+        // FFN
+        ggml_tensor * ffn_residual = cur;
+        
+        // Some draft models use attn_post_norm, others use ffn_norm. We check both.
+        ggml_tensor * post_norm = model.layers[il].attn_post_norm ? model.layers[il].attn_post_norm : model.layers[il].ffn_norm;
+        cur = build_norm(cur, post_norm, nullptr, LLM_NORM_RMS, il);
+
+        cur = build_ffn(cur,
+            model.layers[il].ffn_up,   nullptr, nullptr,
+            model.layers[il].ffn_gate, nullptr, nullptr,
+            model.layers[il].ffn_down, nullptr, nullptr,
+            nullptr, LLM_FFN_SILU, LLM_FFN_PAR, il);
+
+        cur = ggml_add(ctx0, cur, ffn_residual);
+    }
+
+    // Final Norm
+    cur = ggml_rms_norm(ctx0, cur, hparams.f_norm_rms_eps);
+    cur = ggml_mul(ctx0, cur, model.output_norm);
+
+    // Logits
+    ggml_tensor * output_use = model.output;
+    if (!output_use) {
+        output_use = ggml_new_tensor_2d(ctx0, GGML_TYPE_Q4_0, n_embd, model.vocab.n_tokens());
+    }
+    cur = ggml_mul_mat(ctx0, output_use, cur);
+    res->t_logits = cur;
+
+    // Sampling
+    float sample_temp = cparams.dflash_sample_temp;
+    uint64_t seed = cparams.dflash_seed;
+    int topk = cparams.dflash_topk;
+
+    if (topk > 1) {
+        res->t_logits_argmax = ggml_topk_ext(ctx0, cur, topk, sample_temp, seed);
+    } else {
+        res->t_logits_argmax = ggml_argmax_ext(ctx0, cur, sample_temp, seed);
+    }
+
+    ggml_build_forward_expand(gf, res->t_logits_argmax);
+}
