--- /dev/null
+++ b/tests/test-dflash-server.sh
@@ -0,0 +1,50 @@
+#!/bin/bash
+
+# DFlash Server Integration Test
+# Validates that the server is running with DFlash and accepting tokens.
+
+SERVER_URL="http://127.0.0.1:1337"
+
+echo "Checking server health..."
+HEALTH=$(curl -s "$SERVER_URL/health")
+if [[ "$HEALTH" != *"ok"* ]]; then
+    echo "Error: Server not healthy or not reachable at $SERVER_URL"
+    exit 1
+fi
+echo "Health OK."
+
+echo "Checking slots for DFlash activation..."
+SLOTS=$(curl -s "$SERVER_URL/slots")
+if [[ "$SLOTS" == *"\"speculative\":true"* ]]; then
+    echo "DFlash speculative engine detected in slots."
+else
+    echo "Error: DFlash speculative engine not active in server slots."
+    exit 1
+fi
+
+echo "Running completion test..."
+RESPONSE=$(curl -s "$SERVER_URL/completion" \
+  -H "Content-Type: application/json" \
+  -d '{
+    "prompt": "Hello",
+    "n_predict": 10,
+    "stream": false
+  }')
+
+if [[ "$RESPONSE" == *"\"speculative.type\":\"dflash\""* ]]; then
+    echo "DFlash confirmed in generation settings."
+else
+    echo "Error: speculative.type is not dflash in response."
+    echo "Response: $RESPONSE"
+    exit 1
+fi
+
+if [[ "$RESPONSE" == *"\"content\":"* ]]; then
+    echo "Generation successful."
+else
+    echo "Error: No content generated."
+    exit 1
+fi
+
+echo "DFlash integration validation PASSED."
+exit 0
