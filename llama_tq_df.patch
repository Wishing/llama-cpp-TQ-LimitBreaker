+            common_time_meas tm(impl->t_draft_us, !impl->gen_perf);
+            impl->draft_tree(params, prompt_tgt, id_last, tree_budget, tree);
+            impl->n_call_draft++;
+        }
+
+        if (tree.n_nodes > 0) {
+            spec->curr_impl = impl.get();
+            impl->n_gen_drafts++;
+            impl->n_gen_tokens += tree.n_nodes;
+            break;
+        }
+    }
+
+    return tree;
+}
