 void llm_graph_context::cb(ggml_tensor * cur, const char * name, int il) const {
+    if (il >= 0) {
+        ggml_format_name(cur, "%s-%d", name, il);
+    } else {
+        ggml_set_name(cur, name);
+    }
+ 
+    if (cparams.tape_gpu != nullptr && il >= 0) {
+        dflash_tape_gpu * tape = (dflash_tape_gpu *) cparams.tape_gpu;
+        // find if this layer is in the tape
+        int tape_idx = -1;
+        for (int i = 0; i < (int) tape->layer_ids.size(); ++i) {
+            if (tape->layer_ids[i] == il) {
+                tape_idx = i;
+                break;
+            }
+        }
+ 
+        if (tape_idx >= 0) {
+            auto & tl = tape->layers[tape_idx];
+            ggml_tensor * target = nullptr;
+            if      (strcmp(name, "k_conv_predelta") == 0) target = tl.k;
+            else if (strcmp(name, "v_conv_predelta") == 0) target = tl.v;
+            else if (strcmp(name, "gate")            == 0) target = tl.gate;
+            else if (strcmp(name, "beta")            == 0) target = tl.beta;
+ 
+            if (target) {
+                // record the tokens into the tape
+                // target shape: [D, H, max_tokens]
+                // cur shape:    [D, H, n_tokens, n_seqs]
+                // we only support n_seqs == 1 for now in tape recording (verify pass)
+                GGML_ASSERT(cur->ne[3] == 1);
+                ggml_build_forward_expand(gf, ggml_cpy(ctx0, cur, ggml_view_3d(ctx0, target, target->ne[0], target->ne[1], cur->ne[2], target->nb[1], target->nb[2], 0)));
+            }
+        }
+    }
+
+    if (strcmp(name, "ssm_states") == 0 && il >= 0) {
+        if (tree_ssm_intermediates) {
+            auto & intermediates = *tree_ssm_intermediates;
+            ggml_tensor * target = intermediates[il];
+            ggml_build_forward_expand(gf, ggml_cpy(ctx0, cur, ggml_view_3d(ctx0, target, target->ne[0], target->ne[1], cur->ne[2], target->nb[1], target->nb[2], 0)));
+        }
+    }
+ 
     if (cb_func) {
         cb_func(ubatch, cur, name, il);
     }
